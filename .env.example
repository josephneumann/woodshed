# The Woodshed — environment configuration.
# Copy to .env and fill in. .env is gitignored — never commit real secrets.

# Anthropic API key for the embedded Instructor (coach). Server-side only; it is
# never sent to the browser. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: xAI key for regenerating the artwork (gear portraits, motifs, plates)
# with Grok Imagine via the scripts in scripts/. Not needed to run the app.
XAI_API_KEY=

# Your login name for the standalone server.
WOODSHED_USER=yourname

# scrypt hash of your password. Generate it (never store the plaintext):
#   npm run hash-pass 'your password here'
# then paste the printed scrypt:... string below.
WOODSHED_PASS_HASH=

# Port the standalone server listens on (Caddy reverse-proxies to this).
PORT=8787

# Secure cookies + HSTS. Keep this 1 in production (you MUST be behind HTTPS/Caddy).
# Set to 0 ONLY for plain-HTTP local testing on localhost, where Secure cookies
# would otherwise never be sent back.
WOODSHED_SECURE=1
